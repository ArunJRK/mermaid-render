{
  "name": "@mermaid-render/core",
  "version": "0.1.0",
  "description": "Interactive Mermaid diagram rendering engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mermaid": "11.4.1",
    "@dagrejs/dagre": "^1.1.4",
    "pixi.js": "^8.6.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^3.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
